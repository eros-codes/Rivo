generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  username     String    @unique
  email        String    @unique
  bio          String?
  profilePics  String[]
  isOnline     Boolean   @default(false)
  lastSeen     DateTime?
  privacyOnline  String @default("everyone")
  privacyEmail   String @default("everyone")
  privacyProfile String @default("everyone")
  passwordHash String
  createdAt    DateTime  @default(now())

  ownedContacts  Contact[] @relation("owner")
  contacts       Contact[] @relation("contact")
  messages       Message[]
  conversations  ConversationMember[]
}

model Contact {
  id             Int          @id @default(autoincrement())
  owner          User         @relation("owner", fields: [ownerId], references: [id])
  ownerId        Int
  contact        User         @relation("contact", fields: [contactId], references: [id])
  contactId      Int
  nickname       String?
  isPinned       Boolean      @default(false)
  pinOrder       Int?
  isMuted        Boolean      @default(false)
  isBlocked      Boolean      @default(false)
  isInChat       Boolean      @default(false)
  isArchived     Boolean      @default(false)
  unreadCount    Int          @default(0)
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId Int
}

model Conversation {
  id            Int                  @id @default(autoincrement())
  createdAt     DateTime             @default(now())
  lastMessageAt DateTime?
  members       ConversationMember[]
  messages      Message[]
  contacts      Contact[]
}

model ConversationMember {
  id             Int          @id @default(autoincrement())
  user           User         @relation(fields: [userId], references: [id])
  userId         Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId Int
}

model Message {
  id             Int          @id @default(autoincrement())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId Int
  sender         User         @relation(fields: [senderId], references: [id])
  senderId       Int
  text           String
  isSeen         Boolean      @default(false)
  isEdited       Boolean      @default(false)
  isPinned       Boolean      @default(false)
  isDeleted      Boolean      @default(false)
  replyToId      Int?
  replyToName    String?
  replyToText    String?
  forwardedFrom  String?
  forwardedText  String?
  createdAt      DateTime     @default(now())
}