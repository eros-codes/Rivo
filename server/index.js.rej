+// Build CSP directives dynamically by hashing inline <script> and <style>
+// content found in HTML files we serve (index and src pages). This allows
+// blocking 'unsafe-inline' while permitting the existing inline blocks.
+function computeHashesFromHtml(filePath, scriptSet, styleSet) {
+	try {
+		const html = readFileSync(filePath, "utf8");
+		let m;
+		const scriptRe = /<script(?![^>]*src)[^>]*>([\s\S]*?)<\/script>/gi;
+		while ((m = scriptRe.exec(html)) !== null) {
+			const raw = m[1] || "";
+			if (raw.length === 0) continue;
+			// compute hashes for a few common normalizations to avoid mismatches
+			const variants = new Set();
+			variants.add(raw);
+			variants.add(raw.trim());
+			variants.add(raw.replace(/\r\n/g, "\n"));
+			variants.add(raw.replace(/\r\n/g, "\n").trim());
+			variants.add(raw.replace(/\n/g, "\r\n"));
+			variants.add(raw.replace(/\n/g, "\r\n").trim());
+			for (const v of variants) {
+				if (!v) continue;
+				const digest = createHash("sha256").update(v, "utf8").digest("base64");
+				scriptSet.add(`'sha256-${digest}'`);
+			}
+		}
+		const styleRe = /<style[^>]*>([\s\S]*?)<\/style>/gi;
+		while ((m = styleRe.exec(html)) !== null) {
+			const raw = m[1] || "";
+			if (raw.length === 0) continue;
+			const variants = new Set();
+			variants.add(raw);
+			variants.add(raw.trim());
+			variants.add(raw.replace(/\r\n/g, "\n"));
+			variants.add(raw.replace(/\r\n/g, "\n").trim());
+			variants.add(raw.replace(/\n/g, "\r\n"));
+			variants.add(raw.replace(/\n/g, "\r\n").trim());
+			for (const v of variants) {
+				if (!v) continue;
+				const digest = createHash("sha256").update(v, "utf8").digest("base64");
+				styleSet.add(`'sha256-${digest}'`);
+			}
+		}
+	} catch (e) {
+		// ignore missing files or parse errors
+	}
+}
